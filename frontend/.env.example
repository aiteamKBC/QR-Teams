# Optional override. If omitted, frontend defaults to same-origin `/api`.
# VITE_API_BASE_URL=https://<FRONTEND_NGROK_DOMAIN>
# Optional override for Teams config page. If omitted, defaults to current window origin.
# VITE_PUBLIC_APP_BASE_URL=https://<FRONTEND_NGROK_DOMAIN>
# Production example:
# VITE_API_BASE_URL=https://api.yourdomain.com
# VITE_PUBLIC_APP_BASE_URL=https://app.yourdomain.com
# Optional brand logo URL for student-facing QR panel.
# If omitted, defaults to /kent-logo.png
# VITE_BRAND_LOGO_URL=https://your-logo-url-or-public-path
# Optional debug mode for Teams QR panel controls/technical fields.
# VITE_DEBUG_QR_PANEL=true
