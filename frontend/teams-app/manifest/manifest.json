{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "2.0.8",
  "id": "1cdc607e-a139-4efa-bb3f-e5425c35741e",
  "name": {
    "short": "KBC Attendance",
    "full": "KBC Attendance Panel"
  },
  "developer": {
    "name": "KBC Attendance",
    "websiteUrl": "https://qrteams.kentbusinesscollege.net",
    "privacyUrl": "https://qrteams.kentbusinesscollege.net",
    "termsOfUseUrl": "https://qrteams.kentbusinesscollege.net"
  },
  "description": {
    "short": "Show live meeting QR for attendance",
    "full": "Displays the active QR session for a Teams meeting and auto-refreshes live attendance QR data."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#4F46E5",
  "configurableTabs": [
    {
      "configurationUrl": "https://qrteams.kentbusinesscollege.net/teams/qr-panel",
      "canUpdateConfiguration": true,
      "scopes": [
        "groupChat"
      ],
      "context": [
        "meetingChatTab",
        "meetingDetailsTab",
        "meetingSidePanel",
        "meetingStage"
      ]
    }
  ],
  "staticTabs": [
    {
      "entityId": "qr-panel-static",
      "name": "QR Panel",
      "contentUrl": "https://qrteams.kentbusinesscollege.net/teams/qr-panel",
      "websiteUrl": "https://qrteams.kentbusinesscollege.net/teams/qr-panel",
      "scopes": [
        "groupChat"
      ],
      "context": [
        "meetingChatTab",
        "meetingDetailsTab",
        "meetingSidePanel"
      ]
    }
  ],
  "meetingExtensionDefinition": {
    "scenes": [],
    "supportsStreaming": false
  },
  "permissions": [
    "identity",
    "messageTeamMembers"
  ],
  "defaultInstallScope": "meetings",
  "defaultGroupCapability": {
    "meetings": "tab"
  },
  "validDomains": [
    "qrteams.kentbusinesscollege.net"
  ]
}