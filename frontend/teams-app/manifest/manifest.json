{
  "$schema": "https://developer.microsoft.com/en-us/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "2.0.21",
  "id": "4f3868b0-34ed-4a23-a940-8a38c4a2c4cf",
  "name": {
    "short": "KBC Attendance",
    "full": "KBC Attendance Panel"
  },
  "developer": {
    "name": "KBC Attendance",
    "websiteUrl": "https://qrteams.kentbusinesscollege.net",
    "privacyUrl": "https://qrteams.kentbusinesscollege.net",
    "termsOfUseUrl": "https://qrteams.kentbusinesscollege.net"
  },
  "description": {
    "short": "Show live meeting QR for attendance",
    "full": "Displays the active QR session for a Teams meeting and auto-refreshes live attendance QR data."
  },
  "icons": {
    "outline": "outline.png",
    "color": "color.png"
  },
  "accentColor": "#4F46E5",
  "configurableTabs": [
    {
      "configurationUrl": "https://qrteams.kentbusinesscollege.net/teams/config",
      "canUpdateConfiguration": false,
      "scopes": [
        "team",
        "groupChat"
      ],
      "context": [
        "channelTab",
        "meetingChatTab",
        "meetingDetailsTab",
        "meetingSidePanel",
        "meetingStage"
      ]
    }
  ],
  "authorization": {
    "permissions": {
      "resourceSpecific": [
        {
          "type": "Delegated",
          "name": "MeetingStage.Write.Chat"
        },
        {
          "type": "Delegated",
          "name": "ChannelMeetingStage.Write.Group"
        }
      ]
    }
  },
  "validDomains": [
    "qrteams.kentbusinesscollege.net"
  ]
}
