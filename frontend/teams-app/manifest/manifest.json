      "scopes": [
        "personal",
        "groupChat"
      ],
      "context": [
        "personalTab",
        "meetingChatTab",
        "meetingDetailsTab",
        "meetingSidePanel",
        "meetingStage"
      ]
    }
  ],
  "activities": {
    "activityTypes": [
      {
        "type": "attendanceReady",
