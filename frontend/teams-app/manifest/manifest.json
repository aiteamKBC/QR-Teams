{
  "$schema": "https://developer.microsoft.com/json-schemas/teams/v1.17/MicrosoftTeams.schema.json",
  "manifestVersion": "1.17",
  "version": "1.0.0",
  "id": "6f0fb0d3-0568-4f16-8fb8-5f6db8bd7fcb",
  "developer": {
    "name": "QR Teams",
    "websiteUrl": "https://gastroenteritic-semisolemnly-kelly.ngrok-free.dev",
    "privacyUrl": "https://gastroenteritic-semisolemnly-kelly.ngrok-free.dev",
