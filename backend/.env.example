DJANGO_SECRET_KEY=<SET_A_STRONG_SECRET_KEY>
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.yourdomain.com

DATABASE_URL=postgresql://<USER>:<PASSWORD>@<HOST>/<DB_NAME>?sslmode=require&channel_binding=require
NGROK_BACKEND_HOST=<YOUR_BACKEND_NGROK_DOMAIN>
PUBLIC_FRONTEND_ORIGIN=https://app.yourdomain.com
# Optional legacy alias (still supported):
# NGROK_FRONTEND_ORIGIN=https://app.yourdomain.com

# Microsoft Graph scaffold (meeting chat app auto-install).
# TODO: set real values before enabling auto-install flow.
MS_GRAPH_TENANT_ID=<YOUR_AZURE_TENANT_ID>
MS_GRAPH_CLIENT_ID=<YOUR_AZURE_APP_CLIENT_ID>
MS_GRAPH_CLIENT_SECRET=<YOUR_AZURE_APP_CLIENT_SECRET>
TEAMS_APP_CATALOG_ID=<YOUR_TEAMS_APP_CATALOG_APP_ID>
# Optional override for GCC/sovereign endpoints if needed:
# MS_GRAPH_BASE_URL=https://graph.microsoft.com/v1.0
# Optional local testing shortcut:
# MS_GRAPH_ACCESS_TOKEN_OVERRIDE=<SHORT_LIVED_GRAPH_ACCESS_TOKEN>

# Teams deep-link + activity notification settings.
# TEAMS_MANIFEST_APP_ID is the Teams app ID from manifest.json ("id").
TEAMS_MANIFEST_APP_ID=<YOUR_TEAMS_MANIFEST_APP_ID>
TEAMS_QR_TAB_ENTITY_ID=qr-panel-static
TEAMS_QR_PANEL_PUBLIC_URL=https://app.yourdomain.com/teams/qr-panel
TEAMS_ACTIVITY_TYPE=attendanceReady
